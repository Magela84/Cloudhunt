{
  "name": "cloudhunt",
  "version": "0.1.0",
  "private": true,
  "description": "CloudHunt — Cloud Engineer job finder, resume tailor & application cockpit",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
